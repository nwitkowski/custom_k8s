**/.DS_Store

# Local .terraform directory (plugins, modules, providers)
**/.terraform/

# State files — never commit these
**/*.tfstate
**/*.tfstate.*
**/*.tfstate.backup

# Plan output files (may embed sensitive variable values, e.g. tokens)
**/*.tfplan
**/*.plan
**/tfplan

# Local Claude Code session/config
.claude/

# Variable files — often contain secrets
**/*.tfvars
**/*.tfvars.json

# Override files (local dev overrides)
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Crash logs
**/crash.log
**/crash.*.log


# E2E run logs
logs/
