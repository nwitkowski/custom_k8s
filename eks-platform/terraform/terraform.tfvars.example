# Cluster region — where the EKS cluster + VPC are created. Students use this
# same value as CLUSTER_REGION in Lab 1. US classes: us-east-2 (cluster) /
# us-east-1 (Cloud9). EU classes: eu-west-3 (cluster) / eu-central-1 (Cloud9).
# Pick a region with 3+ AZs for the scheduling labs.
aws_region           = "us-east-2"
cluster_name         = "platform-lab"
cluster_version      = "1.33"
vpc_cidr             = "10.0.0.0/16"
node_instance_type   = "m5.2xlarge"
node_desired         = 6
node_min             = 4
node_max             = 8
github_owner         = "jwkidd3"
flux_repository_name = "fleet-infra"
# github_token       = "ghp_..."  # pass via TF_VAR_github_token

# ─── DNS (optional) ──────────────────────────────────────────────────────
# Set enable_dns = true after creating a Route 53 hosted zone
# enable_dns      = true
# route53_zone_id = "Z0123456789ABCDEFGHIJ"
# domain          = "example.com"
